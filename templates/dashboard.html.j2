<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Idea Validation Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<style>
  :root {
    --go: #22c55e; --go-bg: #dcfce7; --go-text: #14532d;
    --conditional: #f59e0b; --conditional-bg: #fef3c7; --conditional-text: #78350f;
    --pause: #6b7280; --pause-bg: #f3f4f6; --pause-text: #1f2937;
    --nogo: #ef4444; --nogo-bg: #fee2e2; --nogo-text: #7f1d1d;
    --bg: #0f172a; --surface: #1e293b; --surface2: #334155;
    --text: #e2e8f0; --text-muted: #94a3b8; --accent: #38bdf8;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; }
  .container { max-width: 1400px; margin: 0 auto; padding: 2rem; }

  header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
  h1 { font-size: 1.75rem; }
  .subtitle { color: var(--text-muted); }

  /* Filters */
  .filters { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .filter-btn {
    padding: 0.4rem 0.9rem; border-radius: 6px; border: 1px solid var(--surface2);
    background: var(--surface); color: var(--text-muted); cursor: pointer; font-size: 0.85rem;
    transition: all 0.2s;
  }
  .filter-btn:hover, .filter-btn.active { border-color: var(--accent); color: var(--accent); }

  /* Ranking Table */
  .table-container { overflow-x: auto; margin-bottom: 2.5rem; }
  table { width: 100%; border-collapse: collapse; }
  th { text-align: left; padding: 0.75rem 1rem; color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 2px solid var(--surface2); }
  td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--surface2); }
  tr:hover td { background: var(--surface); }
  .rank { font-weight: 700; color: var(--accent); font-size: 1.1rem; }

  .verdict-pill {
    display: inline-block; padding: 0.2rem 0.6rem; border-radius: 4px;
    font-size: 0.75rem; font-weight: 700; white-space: nowrap;
  }
  .verdict-GO { background: var(--go); color: #fff; }
  .verdict-CONDITIONAL_GO { background: var(--conditional); color: #fff; }
  .verdict-PAUSE { background: var(--pause); color: #fff; }
  .verdict-NO_GO { background: var(--nogo); color: #fff; }

  .composite { font-size: 1.5rem; font-weight: 800; }
  .expand-btn {
    background: none; border: 1px solid var(--surface2); color: var(--text-muted);
    padding: 0.3rem 0.7rem; border-radius: 4px; cursor: pointer; font-size: 0.8rem;
  }
  .expand-btn:hover { border-color: var(--accent); color: var(--accent); }

  /* Expandable detail rows */
  .detail-row td { padding: 0; border: none; }
  .detail-content {
    display: none; padding: 1.5rem; background: var(--surface);
    border-bottom: 2px solid var(--surface2);
  }
  .detail-content.open { display: block; }
  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .detail-section h3 { font-size: 0.9rem; color: var(--accent); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .detail-item { background: var(--surface2); padding: 0.75rem; border-radius: 6px; margin-bottom: 0.5rem; font-size: 0.9rem; }
  .detail-item strong { color: var(--accent); }

  /* Radar charts grid */
  .charts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
  .chart-card { background: var(--surface); border-radius: 12px; padding: 1.5rem; }
  .chart-card h3 { font-size: 1rem; margin-bottom: 0.5rem; }
  .chart-card .thesis { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem; }

  /* Score mini bars */
  .mini-bar { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem; }
  .mini-bar-label { font-size: 0.7rem; color: var(--text-muted); width: 120px; text-align: right; }
  .mini-bar-track { flex: 1; height: 4px; background: var(--surface2); border-radius: 2px; }
  .mini-bar-fill { height: 100%; border-radius: 2px; }
  .mini-bar-val { font-size: 0.75rem; font-weight: 600; min-width: 1.5rem; }
</style>
</head>
<body>
<div class="container">
  <header>
    <div>
      <h1>Idea Validation Dashboard</h1>
      <p class="subtitle">{{ ideas | length }} idea{{ "s" if ideas | length != 1 }} analyzed</p>
    </div>
    <div class="filters">
      <button class="filter-btn active" onclick="filterIdeas('all', this)">All</button>
      <button class="filter-btn" onclick="filterIdeas('GO', this)">GO</button>
      <button class="filter-btn" onclick="filterIdeas('CONDITIONAL_GO', this)">Conditional</button>
      <button class="filter-btn" onclick="filterIdeas('PAUSE', this)">Pause</button>
      <button class="filter-btn" onclick="filterIdeas('NO_GO', this)">No Go</button>
    </div>
  </header>

  <!-- Ranked Table -->
  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Idea</th>
          <th>Verdict</th>
          <th>Score</th>
          {% for label in score_labels %}
          <th style="font-size:0.7rem; writing-mode:vertical-lr; text-orientation:mixed; max-width:2rem;">{{ label | replace("_", " ") | title }}</th>
          {% endfor %}
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for idea in ideas %}
        {% set verdict = idea.scores.verdict | default("N/A") %}
        <tr class="idea-row" data-verdict="{{ verdict }}" data-idx="{{ loop.index0 }}">
          <td class="rank">{{ loop.index }}</td>
          <td>
            <div style="font-weight:600;">{{ idea.name }}</div>
            <div style="font-size:0.8rem; color:var(--text-muted);">{{ idea.thesis[:80] }}{% if idea.thesis | length > 80 %}...{% endif %}</div>
          </td>
          <td><span class="verdict-pill verdict-{{ verdict }}">{{ verdict | replace("_", " ") }}</span></td>
          <td class="composite">{{ "%.1f" | format(idea.scores.composite_score | default(0)) }}</td>
          {% for label in score_labels %}
          {% set sv = idea.scores.scores[label] %}
          {% set s = sv.score if sv is mapping else sv %}
          <td style="text-align:center; font-weight:600; color:{% if s >= 7 %}var(--go){% elif s >= 5 %}var(--conditional){% elif s >= 3 %}var(--pause){% else %}var(--nogo){% endif %};">{{ s }}</td>
          {% endfor %}
          <td><button class="expand-btn" onclick="toggleDetail({{ loop.index0 }})">Details</button></td>
        </tr>
        <tr class="detail-row" data-verdict="{{ verdict }}">
          <td colspan="{{ score_labels | length + 4 }}">
            <div class="detail-content" id="detail-{{ loop.index0 }}">
              <div class="detail-grid">
                <div class="detail-section">
                  <h3>Key Findings</h3>
                  {% for f in idea.analysis.get("synthesis", {}).get("cross_validated_findings", [])[:5] %}
                  <div class="detail-item"><strong>{{ f.id }}:</strong> {{ f.title }} — {{ f.summary[:150] }}{% if f.summary | length > 150 %}...{% endif %}</div>
                  {% endfor %}
                  {% if not idea.analysis.get("synthesis", {}).get("cross_validated_findings") %}
                  <div class="detail-item" style="color:var(--text-muted);">No synthesis data</div>
                  {% endif %}
                </div>
                <div class="detail-section">
                  <h3>Top Challenges</h3>
                  {% for c in idea.analysis.get("devils_advocate", {}).get("challenges", [])[:5] %}
                  <div class="detail-item"><strong>{{ c.severity | upper }}:</strong> {{ c.challenge_title }} — {{ c.challenge_detail[:150] }}{% if c.challenge_detail | length > 150 %}...{% endif %}</div>
                  {% endfor %}
                  {% if not idea.analysis.get("devils_advocate", {}).get("challenges") %}
                  <div class="detail-item" style="color:var(--text-muted);">No challenge data</div>
                  {% endif %}
                </div>
              </div>
              {% if idea.scores.recommended_next_step %}
              <div style="margin-top:1rem; padding:0.75rem; background:var(--surface2); border-radius:6px; border-left:3px solid var(--accent);">
                <strong>Next Step:</strong> {{ idea.scores.recommended_next_step }}
              </div>
              {% endif %}
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <!-- Radar Charts -->
  <h2 style="margin-bottom:1rem; color:var(--accent);">Score Profiles</h2>
  <div class="charts-grid">
    {% for idea in ideas %}
    <div class="chart-card idea-chart" data-verdict="{{ idea.scores.verdict | default('N/A') }}">
      <h3>{{ idea.name }} <span class="verdict-pill verdict-{{ idea.scores.verdict | default('N/A') }}" style="font-size:0.65rem;">{{ idea.scores.verdict | default('N/A') | replace("_", " ") }}</span></h3>
      <p class="thesis">{{ idea.thesis[:100] }}{% if idea.thesis | length > 100 %}...{% endif %}</p>
      <canvas id="chart-{{ loop.index0 }}" height="250"></canvas>
    </div>
    {% endfor %}
  </div>
</div>

<script>
// Chart colors per idea
const chartColors = [
  {bg: 'rgba(56,189,248,0.2)', border: '#38bdf8'},
  {bg: 'rgba(168,85,247,0.2)', border: '#a855f7'},
  {bg: 'rgba(34,197,94,0.2)', border: '#22c55e'},
  {bg: 'rgba(251,146,60,0.2)', border: '#fb923c'},
  {bg: 'rgba(236,72,153,0.2)', border: '#ec4899'},
  {bg: 'rgba(20,184,166,0.2)', border: '#14b8a6'},
];

const scoreLabels = {{ score_labels | tojson }};
const prettyLabels = scoreLabels.map(l => l.replace(/_/g, ' '));

const ideasData = [
  {% for idea in ideas %}
  {
    name: {{ idea.name | tojson }},
    scores: scoreLabels.map(l => {
      const v = {{ idea.scores.scores | tojson }}[l];
      return typeof v === 'object' ? v.score : v;
    })
  },
  {% endfor %}
];

// Create radar charts
ideasData.forEach((idea, i) => {
  const canvas = document.getElementById('chart-' + i);
  if (!canvas) return;
  const color = chartColors[i % chartColors.length];
  new Chart(canvas, {
    type: 'radar',
    data: {
      labels: prettyLabels,
      datasets: [{
        label: idea.name,
        data: idea.scores,
        backgroundColor: color.bg,
        borderColor: color.border,
        borderWidth: 2,
        pointBackgroundColor: color.border,
      }]
    },
    options: {
      scales: {
        r: {
          min: 0, max: 10,
          ticks: { stepSize: 2, color: '#94a3b8', backdropColor: 'transparent' },
          grid: { color: '#334155' },
          angleLines: { color: '#334155' },
          pointLabels: { color: '#e2e8f0', font: { size: 10 } }
        }
      },
      plugins: { legend: { display: false } }
    }
  });
});

// Toggle detail rows
function toggleDetail(idx) {
  const el = document.getElementById('detail-' + idx);
  el.classList.toggle('open');
}

// Filter by verdict
function filterIdeas(verdict, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  document.querySelectorAll('.idea-row, .detail-row, .idea-chart').forEach(el => {
    if (verdict === 'all' || el.dataset.verdict === verdict) {
      el.style.display = '';
    } else {
      el.style.display = 'none';
    }
  });
}
</script>
</body>
</html>
